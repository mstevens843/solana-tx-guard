{
  "name": "@txshield/core",
  "version": "0.0.1",
  "description": "TxShield core — decode a Solana transaction and produce a RiskReport. Runtime-agnostic trust anchor.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mstevens843/solana-tx-guard.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/mstevens843/solana-tx-guard/issues"
  },
  "homepage": "https://github.com/mstevens843/solana-tx-guard/tree/main/packages/core#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  }
}
