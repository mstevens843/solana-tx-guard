{
  "name": "@txshield/registry",
  "version": "0.0.1",
  "description": "TxShield offline registry — program allowlist, drainer denylist, trusted-mint registry. Ships without a network dependency.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mstevens843/solana-tx-guard.git",
    "directory": "packages/registry"
  },
  "bugs": {
    "url": "https://github.com/mstevens843/solana-tx-guard/issues"
  },
  "homepage": "https://github.com/mstevens843/solana-tx-guard/tree/main/packages/registry#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@txshield/core": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  }
}
