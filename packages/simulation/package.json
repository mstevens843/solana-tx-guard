{
  "name": "@txshield/simulation",
  "version": "0.0.1",
  "description": "TxShield optional RPC enrichment + the open Lighthouse atomic-guard. Advisory only; never the trust anchor.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mstevens843/solana-tx-guard.git",
    "directory": "packages/simulation"
  },
  "bugs": {
    "url": "https://github.com/mstevens843/solana-tx-guard/issues"
  },
  "homepage": "https://github.com/mstevens843/solana-tx-guard/tree/main/packages/simulation#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@solana/kit": "^2.3.0",
    "@txshield/core": "workspace:*",
    "lighthouse-sdk": "^2.0.1"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  }
}
