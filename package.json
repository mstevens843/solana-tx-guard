{
  "name": "txshield-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "TxShield — open, embeddable Solana transaction-safety layer. Pre-sign drain detection + open on-chain atomic-guard.",
  "license": "MIT",
  "author": "Mathew Stevens",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20.16.13",
    "tsup": "^8.3.0",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
